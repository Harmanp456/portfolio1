# EmailJS Configuration
# Get these from https://www.emailjs.com/
# 1. Sign up at emailjs.com (free)
# 2. Create an Email Service (connect your Gmail)
# 3. Create an Email Template with variables: {{from_name}}, {{from_email}}, {{message}}, {{to_name}}
# 4. Copy your Service ID, Template ID, and Public Key below

NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here
# Optional: dedicated template for owner inbox notification.
# Falls back to NEXT_PUBLIC_EMAILJS_TEMPLATE_ID when omitted.
NEXT_PUBLIC_EMAILJS_OWNER_TEMPLATE_ID=your_owner_template_id_here
# Optional: dedicated template for visitor auto-reply.
# Falls back to NEXT_PUBLIC_EMAILJS_TEMPLATE_ID when omitted.
NEXT_PUBLIC_EMAILJS_AUTOREPLY_TEMPLATE_ID=your_autoreply_template_id_here
# Optional: where contact messages should be delivered.
# If omitted, app falls back to puneetshankar2021@gmail.com
NEXT_PUBLIC_CONTACT_RECEIVER_EMAIL=your_email@example.com
